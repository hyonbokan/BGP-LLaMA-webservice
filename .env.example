# BGP-LLaMA backend configuration. Copy to .env and fill in.
# Field <- ENV mapping is case-insensitive (see app/core/config.py). Unknown keys
# are ignored. List fields are JSON arrays (pydantic-settings native format).

# Logging
LOG_LEVEL=INFO

# HTTP / CORS — JSON array of allowed origins.
CORS_ALLOWED_ORIGINS=["http://localhost:3000"]

# Shared LLM client
LLM_REQUEST_TIMEOUT=120

# Conversation memory (token thresholds; ~4 chars/token estimate)
GPT_HISTORY_MAX_TOKENS=100000
LLAMA_HISTORY_MAX_TOKENS=60000
HISTORY_KEEP_RECENT_TURNS=4

# Hosted GPT (OpenAI or any OpenAI-compatible gateway via OPENAI_BASE_URL).
# No temperature / max-tokens knobs — reasoning models ignore them.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini-2026-03-17
# OPENAI_BASE_URL=

# Query classification (structured LLM call, always GPT-backed)
CLASSIFIER_ENABLED=true
# CLASSIFIER_MODEL=            # blank => use OPENAI_MODEL

# Local fine-tuned BGP-LLaMA served by vLLM
LLAMA_BASE_URL=http://host.docker.internal:8000/v1
LLAMA_API_KEY=EMPTY
LLAMA_MODEL=hyonbokan/bgp-llama-3.1-instruct-10kSteps-2kDataset
LLAMA_TEMPERATURE=0.1
LLAMA_MAX_TOKENS=912
LLAMA_REPETITION_PENALTY=1.1
LLAMA_API_MODE=completion      # "completion" (raw prompt) or "chat"

# Agentic BGP analysis (opencode-agent-pod). Keys live in the pod; this backend
# sends a rendered task + bearer token. The backend gathers/stages BGP data and
# the agent analyzes it (no fetch tool). AGENT_TOOLS is a JSON array.
AGENT_POD_URL=http://localhost:8080
AGENT_POD_TOKEN=local-dev-pod-token
AGENT_MODEL=gpt-5.4-mini-2026-03-17
AGENT_TOOLS=["Bash","Read","Write"]
# AGENT_MAX_BUDGET_USD=         # blank => unbounded
AGENT_REQUEST_TIMEOUT=600

# File download root (fine-tuning corpus, served by /api/download)
DATASET_ROOT=finetuning-dataset

# Root dir the backend stages gathered BGP update files under (the agent's workspace)
BGP_DATA_ROOT=/data/bgp
