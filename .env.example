# =============================================================================
# BGP-LLaMA Webservice — environment template
# Copy to `.env` and fill in real values:  cp .env.example .env
# `.env` is git-ignored and read by both Django (project_1.settings.base)
# and the FastAPI agent (fastapi_agent.main) via django-environ.
# =============================================================================

# --- Django core -------------------------------------------------------------
# Selects which settings module __init__.py loads: "development" or "production".
# (docker-compose also sets DJANGO_SETTINGS_MODULE explicitly per environment.)
DJANGO_ENV=development
# Generate one with:
#   python -c "from django.core.management.utils import get_random_secret_key as k; print(k())"
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True

# Comma-separated lists (parsed by env.list()).
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:8000
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:8000

# --- Database (Django connects with these) -----------------------------------
DB_NAME=bgp_llama
DB_USER=bgp_llama
DB_PASSWORD=change-me
# Use "db" when running via docker-compose, "localhost" for a local Postgres.
DB_HOST=db
DB_PORT=5432

# --- Database (Postgres container init — keep in sync with the DB_* values) ---
POSTGRES_DB=bgp_llama
POSTGRES_USER=bgp_llama
POSTGRES_PASSWORD=change-me

# --- OpenAI (GPT-4o-mini chatbot path) ---------------------------------------
OPENAI_API_KEY=sk-...

# --- Hugging Face (BGP-LLaMA model download / gated repos) --------------------
# NOTE: the code reads the lowercase name `hf_token` (app_1/utils/model_loader.py).
hf_token=hf_...

# Host directory mounted into the FastAPI container as the HF cache.
# Defaults to ~/.cache/huggingface if unset (see docker-compose.base.yml).
HF_CACHE_DIR=~/.cache/huggingface
