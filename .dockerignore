# Keep build contexts small and reproducible. Applies to both images
# (docker/Dockerfile.api and docker/Dockerfile.web) — context is the repo root.
.git
.gitignore
.venv
venv
env
__pycache__
*.pyc
*.pyo

# Frontend artifacts: the web image runs `yarn install` + `yarn build` itself,
# so the host's node_modules and build output must never be copied in.
node_modules
react_frontend/node_modules
react_frontend/build

# The fine-tuning corpus is large and mounted at runtime, never baked into an
# image — exclude it from the build context.
finetuning-dataset

# Local env / secrets — provided at runtime via env_file, never baked in.
.env
.env.*
!.env.example

# Editor / OS cruft
.DS_Store
.idea
.vscode
*.log
debug.log

# Docs / research that don't belong in the image
*.md
!README.md
