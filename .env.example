# =============================================================================
# BGP-LLaMA Webservice — environment template
# Copy to `.env` and fill in real values:  cp .env.example .env
# `.env` is git-ignored and read by the FastAPI backend via pydantic-settings
# (app/core/config.py). Unknown keys are ignored, so the vLLM/HF vars below
# (consumed by docker-compose) can live here too.
# =============================================================================

# --- HTTP / logging ----------------------------------------------------------
LOG_LEVEL=INFO
# Comma-separated list of allowed CORS origins.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:8000
# Shared LLM HTTP timeout (seconds).
LLM_REQUEST_TIMEOUT=120

# --- Hosted GPT (BGP-GPT SSE path) -------------------------------------------
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5.4-mini-2026-03-17
# OPENAI_BASE_URL=            # optional: an OpenAI-compatible gateway instead of api.openai.com
GPT_TEMPERATURE=0.7
GPT_MAX_TOKENS=2000

# --- Query classification (structured LLM call, always GPT-backed) -----------
# When disabled, or when OPENAI_API_KEY is empty, chat falls back to a substring
# heuristic — same routing as before, so nothing regresses.
CLASSIFIER_ENABLED=true
# CLASSIFIER_MODEL=           # optional: defaults to OPENAI_MODEL when unset

# --- Conversation memory (multi-turn history + compaction) -------------------
# History is threaded into each request; when it exceeds a provider's window the
# oldest turns are summarized (best-effort GPT) while the most recent are kept.
# Token counts are estimated (~4 chars/token) — no tokenizer dependency.
GPT_HISTORY_MAX_TOKENS=100000
LLAMA_HISTORY_MAX_TOKENS=6000
HISTORY_KEEP_RECENT_TURNS=4

# --- Local BGP-LLaMA served by vLLM (OpenAI-compatible /v1 endpoint) ---------
# In compose the backend reaches vLLM at http://vllm:8000/v1 (set on the service);
# this value is for host/manual runs (vLLM on the host).
LLAMA_BASE_URL=http://host.docker.internal:8000/v1
LLAMA_API_KEY=EMPTY
LLAMA_MODEL=hyonbokan/bgp-llama-3.1-instruct-10kSteps-2kDataset
LLAMA_TEMPERATURE=0.1
LLAMA_MAX_TOKENS=912
LLAMA_REPETITION_PENALTY=1.1
# "completion" sends a raw prompt to /v1/completions (matches the fine-tune);
# "chat" uses /v1/chat/completions with a chat template.
LLAMA_API_MODE=completion

# --- Hugging Face (BGP-LLaMA weights download / gated repos) ------------------
# NOTE: the vLLM container reads the lowercase name `hf_token`.
hf_token=hf_...
# Host directory mounted as the HF cache (defaults to ~/.cache/huggingface).
HF_CACHE_DIR=~/.cache/huggingface

# --- vLLM model server (docker-compose "vllm" service) -----------------------
VLLM_DTYPE=auto
VLLM_MAX_MODEL_LEN=8192
VLLM_GPU_MEMORY_UTILIZATION=0.90
VLLM_TENSOR_PARALLEL_SIZE=1

# --- File downloads ----------------------------------------------------------
# Root directory served by /api/download (the fine-tuning corpus).
DATASET_ROOT=finetuning-dataset

# Root directory generated pybgpstream scripts read BGP update files from.
# Also used to rewrite any personal data path the fine-tuned model reproduces
# from its training data, so no such path leaks into returned code.
BGP_DATA_ROOT=/data/bgp
