# =============================================================================
# BGP-LLaMA Webservice — environment template
# Copy to `.env` and fill in real values:  cp .env.example .env
# `.env` is git-ignored and read by both Django (project_1.settings.base)
# and the FastAPI agent (fastapi_agent.main) via django-environ.
# =============================================================================

# --- Django core -------------------------------------------------------------
# Selects which settings module __init__.py loads: "development" or "production".
# (docker-compose also sets DJANGO_SETTINGS_MODULE explicitly per environment.)
DJANGO_ENV=development
# Generate one with:
#   python -c "from django.core.management.utils import get_random_secret_key as k; print(k())"
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True

# Comma-separated lists (parsed by env.list()).
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:8000
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:8000

# --- Database (Django connects with these) -----------------------------------
DB_NAME=bgp_llama
DB_USER=bgp_llama
DB_PASSWORD=change-me
# Use "db" when running via docker-compose, "localhost" for a local Postgres.
DB_HOST=db
DB_PORT=5432

# --- Database (Postgres container init — keep in sync with the DB_* values) ---
POSTGRES_DB=bgp_llama
POSTGRES_USER=bgp_llama
POSTGRES_PASSWORD=change-me

# --- OpenAI (GPT-4o-mini chatbot path) ---------------------------------------
OPENAI_API_KEY=sk-...

# --- Hugging Face (BGP-LLaMA model download / gated repos) --------------------
# NOTE: the code reads the lowercase name `hf_token` (app_1/utils/model_loader.py).
hf_token=hf_...

# Host directory mounted into the FastAPI container as the HF cache.
# Defaults to ~/.cache/huggingface if unset (see docker-compose.base.yml).
HF_CACHE_DIR=~/.cache/huggingface

# OpenAI model id used by the GPT (BGP-GPT) SSE path
OPENAI_MODEL=gpt-5.4-mini-2026-03-17

# --- Local BGP-LLaMA served by vLLM (OpenAI-compatible /v1 endpoint) ---
LLAMA_BASE_URL=http://host.docker.internal:8000/v1
LLAMA_API_KEY=EMPTY
LLAMA_MODEL=hyonbokan/bgp-llama-3.1-instruct-10kSteps-2kDataset
LLAMA_TEMPERATURE=0.1
LLAMA_MAX_TOKENS=912
LLAMA_REPETITION_PENALTY=1.1

# --- Hosted GPT sampling (OPENAI_API_KEY / OPENAI_MODEL set above) ---
# OPENAI_BASE_URL=            # optional: an OpenAI-compatible gateway instead of api.openai.com
GPT_TEMPERATURE=0.7
GPT_MAX_TOKENS=2000

# Shared LLM HTTP timeout (seconds)
LLM_REQUEST_TIMEOUT=120

# --- vLLM model server (docker-compose "vllm" service) ---
# Local BGP-LLaMA is served by vLLM behind an OpenAI-compatible /v1 API.
# In compose, fastaphi reaches it at http://vllm:8000/v1 (set on the service);
# LLAMA_BASE_URL below is for host/manual runs (vLLM on the host).
LLAMA_API_MODE=completion
VLLM_DTYPE=auto
VLLM_MAX_MODEL_LEN=8192
VLLM_GPU_MEMORY_UTILIZATION=0.90
VLLM_TENSOR_PARALLEL_SIZE=1
